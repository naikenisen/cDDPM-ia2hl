{
    "name": "virtual_staining_hes_to_cd30",
    "gpu_ids": [0],
    "seed" : -1,
    "finetune_norm": false,

    "path": {
        "base_dir": "experiments",
        "code": "code",
        "tb_logger": "tb_logger",
        "results": "results",
        "checkpoint": "checkpoint",
        "resume_state": null
    },

    "datasets": {
        "train": { 
            "which_dataset": {  
                "name": ["data.dataset", "VirtualStainingDataset"], 
                "args":{
                    "data_root": "/work/imvia/in156281/cDDPMv2/dataset/train",
                    "image_size": [512, 512]
                } 
            },
            "dataloader":{
                "args":{
                    "batch_size": 2,
                    "num_workers": 4,
                    "shuffle": true,
                    "pin_memory": true,
                    "drop_last": true
                }
            }
        },
        "val": { 
            "which_dataset": {  
                "name": ["data.dataset", "VirtualStainingDataset"], 
                "args":{
                    "data_root": "/work/imvia/in156281/cDDPMv2/dataset/valid",
                    "image_size": [512, 512]
                } 
            },
            "dataloader":{
                "args":{
                    "batch_size": 2,
                    "num_workers": 4,
                    "shuffle": false,
                    "pin_memory": true,
                    "drop_last": false
                }
            }
        },
        "test": { 
            "which_dataset": {
                "name": ["data.dataset", "VirtualStainingDataset"],
                "args":{
                    "data_root": "/work/imvia/in156281/ia2hl/dataset_tiled_512/test",
                    "image_size": [512, 512]
                }
            },
            "dataloader":{
                "args":{
                    "batch_size": 2,
                    "num_workers": 4,
                    "pin_memory": true
                }
            }
        }
    },

    "model": { 
            "which_model": { 
                "name": ["models.model", "Palette"], 
                "args": {
                    "sample_num": 8, 
                    "task": "translation",
                    "ema_scheduler": {
                        "ema_start": 1,
                        "ema_iter": 1,
                        "ema_decay": 0.9999
                    },
                    "optimizers": [
                        { "lr": 1e-4, "weight_decay": 0}
                    ]
                }
            }, 
            "which_networks": [ 
                {
                    "name": ["models.network", "Network"], 
                    "args": { 
                        "init_type": "kaiming", 
                        "module_name": "guided_diffusion",
                        "unet": {
                            "in_channel": 6,
                            "out_channel": 3,
                            "inner_channel": 128,
                            "channel_mults": [1, 1, 2, 2, 4, 4],
                            "attn_res": [32, 16],
                            "num_head_channels": 32,
                            "res_blocks": 2,
                            "dropout": 0.2,
                            "image_size": 512
                        },
                        "beta_schedule": {
                            "train": {
                                "schedule": "linear",
                                "n_timestep": 2000,
                                "linear_start": 1e-6,
                                "linear_end": 0.01
                            },
                            "test": {
                                "schedule": "linear",
                                "n_timestep": 300, 
                                "linear_start": 1e-6,
                                "linear_end": 0.01
                            }
                        }
                    }
                }
            ],
            "which_losses": [ "mse_loss" ],
            "which_metrics": [ "mae" ]
        },

        "train": { 
            "n_epoch": 350,
            "n_iter": 1e8, 
            "val_epoch": 20, 
            "save_checkpoint_epoch": 20,
            "log_iter": 1e4, 
            "tensorboard" : true 
        }
}